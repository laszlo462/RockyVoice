# Your Hume API key (required). Get it at https://platform.hume.ai
HUME_API_KEY=your-hume-api-key-here

# Optional. Not used by the app today; only the API key above is needed.
HUME_SECRET_KEY=your-hume-secret-key-here

# Your OWN Rocky voice clone id. Voice clones are PRIVATE to the Hume account
# that made them, so you must create your own — a shared id returns 404.
# Quick one-time setup (~1 min): clone the included rocky-voice-sample.mp3 in
# Hume's Voice Library and paste the id here. See README "Part 2 > Voice setup".
# Leave as-is to run with a stock fallback voice until you clone.
HUME_VOICE_ID=your-rocky-voice-id-here

# Optional: stock Hume voice used only until HUME_VOICE_ID is set above.
HUME_FALLBACK_VOICE=Male English Actor

# Optional: speech speed, 0.5–2.0 (higher = faster). Default 1.25.
ROCKY_SPEED=1.5
